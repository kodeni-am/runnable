# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=runnable
DATABASE_USER=runnable
DATABASE_PASSWORD=change_me_in_production

# JWT
JWT_SECRET=change_this_to_a_random_secret_key
JWT_REFRESH_SECRET=change_this_to_another_random_secret_key

# Server
PORT=3001
NODE_ENV=development

# Initial Admin User
# ADMIN_PASSWORD is only used to create the admin on first run. It does NOT
# overwrite a password changed in the app. To force a reset, set
# ADMIN_PASSWORD_RESET=true for one boot — the server applies it, then sets
# this flag back to false automatically.
ADMIN_EMAIL=admin@runnable.dev
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin_password_change_me
ADMIN_PASSWORD_RESET=false

# Hosting
SERV_DIR=/var/runnable/projects
BASE_DOMAIN=runnable.dev
MAX_UPLOAD_SIZE_MB=512

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://api.runnable.dev/api/auth/github/callback

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.runnable.dev/api/auth/google/callback

# Caddy
CADDY_CONFIG_DIR=/etc/caddy/sites
CADDY_ADMIN_API=http://localhost:2019

# Sandbox
SANDBOX_ENABLED=true
SANDBOX_USER_PREFIX=runnable-
