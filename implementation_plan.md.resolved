### 2. Database Schema (TypeORM Entities)

#### [NEW] [server/src/entities/](file:///Users/araasryan/AndroidStudioProjects/runnable/server/src/entities/)

TypeORM entity files:

```typescript
// User.ts
@Entity()
export class User {
  @PrimaryGeneratedColumn("uuid") id: string;
  @Column({ unique: true }) email: string;
  @Column({ unique: true }) username: string;
  @Column({ nullable: true }) passwordHash?: string;  // null for OAuth-only
  @Column({ type: "enum", enum: Role, default: Role.USER }) role: Role;
  @Column({ nullable: true, unique: true }) githubId?: string;
  @Column({ nullable: true, unique: true }) googleId?: string;
  @Column({ nullable: true }) githubToken?: string;   // encrypted
  @OneToMany(() => Project, p => p.user) projects: Project[];
  @CreateDateColumn() createdAt: Date;
  @UpdateDateColumn() updatedAt: Date;
}

// Project.ts
@Entity()
export class Project {
  @PrimaryGeneratedColumn("uuid") id: string;
  @Column() name: string;
  @Column({ unique: true }) subdomain: string;          // myapp → myapp.runnable.dev
  @Column() directoryPath: string;
  @Column({ type: "enum", enum: ServerType }) serverType: ServerType;
  @Column({ type: "enum", enum: ServiceStatus, default: ServiceStatus.STOPPED }) status: ServiceStatus;
  @Column({ nullable: true }) port?: number;
  @Column({ nullable: true }) configPath?: string;
  @ManyToOne(() => User, u => u.projects) user: User;
  @OneToOne(() => GithubRepo, g => g.project) githubRepo?: GithubRepo;
  @OneToMany(() => CustomDomain, d => d.project) customDomains: CustomDomain[];
  @CreateDateColumn() createdAt: Date;
  @UpdateDateColumn() updatedAt: Date;
}

// GithubRepo.ts
@Entity()
export class GithubRepo {
  @PrimaryGeneratedColumn("uuid") id: string;
  @Column() repoUrl: string;
  @Column({ default: "main" }) branch: string;
  @Column({ default: false }) isPrivate: boolean;
  @Column({ nullable: true }) webhookId?: string;
  @Column({ nullable: true }) webhookSecret?: string;
  @Column({ nullable: true }) lastDeployAt?: Date;
  @OneToOne(() => Project, p => p.githubRepo)
  @JoinColumn()
  project: Project;
}

// CustomDomain.ts — NEW: supports custom domains per project
@Entity()
export class CustomDomain {
  @PrimaryGeneratedColumn("uuid") id: string;
  @Column({ unique: true }) domain: string;             // e.g. "mysite.com"
  @Column({ default: false }) sslProvisioned: boolean;   // auto-TLS via Caddy
  @Column({ default: false }) verified: boolean;         // DNS verification
  @ManyToOne(() => Project, p => p.customDomains) project: Project;
  @CreateDateColumn() createdAt: Date;
}

// AppSettings.ts
@Entity()
export class AppSettings {
  @PrimaryColumn({ default: "global" }) id: string;
  @Column({ default: 512 }) maxUploadSizeMB: number;
  @Column({ default: "runnable.dev" }) baseDomain: string;
  @Column() servDir: string;
}

enum Role { ADMIN = "admin", USER = "user" }
enum ServerType { CADDY = "caddy", APACHE = "apache", NGINX = "nginx", STATIC = "static" }
enum ServiceStatus { RUNNING = "running", STOPPED = "stopped", ERROR = "error", DEPLOYING = "deploying" }
```

